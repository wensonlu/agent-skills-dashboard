{
  "name": "@agent-skills-dashboard/core",
  "version": "0.1.8",
  "private": false,
  "description": "Parse SKILL.md files into an Agent Skills graph and recommend next-step skills for AI coding workflows.",
  "keywords": [
    "agent-skills",
    "ai-coding",
    "skill-graph",
    "workflow",
    "typescript"
  ],
  "homepage": "https://github.com/wensonlu/agent-skills-dashboard#readme",
  "bugs": {
    "url": "https://github.com/wensonlu/agent-skills-dashboard/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wensonlu/agent-skills-dashboard.git",
    "directory": "packages/core"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.0.0"
  }
}
